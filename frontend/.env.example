# Frontend environment — copy to .env.local and edit as needed.
# Both are optional: by default the Vite dev server proxies /api → :8000.

# Absolute API origin. Leave unset in dev to use the built-in /api proxy.
# Set this for a deployed build, e.g. https://osint.example.com
# VITE_API_BASE_URL=

# API key — only needed if the backend was started with API_KEY set.
# VITE_API_KEY=
