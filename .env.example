# Copy this file to .env and fill in your values.
# .env is gitignored — never commit credentials.

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, dev): sqlite+aiosqlite:///./data/osint.db
# Postgres  (prod):      postgresql+asyncpg://user:pass@localhost:5432/osint
DATABASE_URL=sqlite+aiosqlite:///./data/osint.db

# ── Graph Backend ─────────────────────────────────────────────────────────────
# "networkx" (default, in-process, no deps) or "neo4j" (requires docker)
GRAPH_BACKEND=networkx

# Neo4j — only needed when GRAPH_BACKEND=neo4j
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ── Scraper ───────────────────────────────────────────────────────────────────
BROWSER_POOL_SIZE=3
# conservative | moderate | aggressive
RATE_PROFILE=moderate
DEFAULT_DEPTH=2
DEFAULT_MAX_ACCOUNTS=500
SELECTOR_VERSION=v1

# ── Proxy ─────────────────────────────────────────────────────────────────────
PROXY_FILE=config/proxies.txt
# Fetch fresh free proxies from proxyscrape on startup?
PROXY_REFRESH_ON_STARTUP=false
PROXY_MIN_POOL_SIZE=5

# ── Sessions ──────────────────────────────────────────────────────────────────
SESSION_DIR=config/sessions

# ── Anti-detection ────────────────────────────────────────────────────────────
UA_POOL_FILE=config/ua_pool.txt
HUMAN_DELAY_MIN_MS=2000
HUMAN_DELAY_MAX_MS=8000

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000
# Uncomment to require API key on all requests:
# API_KEY=your-secret-key-here

# ── Data ──────────────────────────────────────────────────────────────────────
DATA_DIR=./data
MAX_RAW_DATA_AGE_DAYS=30

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# LOG_FILE=/path/to/osint.log
